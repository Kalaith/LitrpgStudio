DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=writers_studio
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=

# JWT Configuration
JWT_SECRET=replace-with-frontpage-jwt-secret
JWT_EXPIRATION=31536000

# API Configuration
API_VERSION=v1
API_BASE_URL=http://localhost:8080
API_BASE_PATH=/
APP_ENV=development
APP_DEBUG=true

# AI Configuration
# AI_PROVIDER auto-detects Gemini, then OpenAI, then OpenAI-compatible local endpoints.
# Supported explicit values: gemini, openai, openai-compatible.
AI_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=http://127.0.0.1:1234
LLM_MODEL=local-model

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
